# sample.agent.env — smoke-test-module login, used from OUTSIDE docker
# (never read by any container). Copy to <instance>.agent.env (mode 600,
# ignored by VCS).

# First-time setup: obtain credentials via `manager/tools/claim_admin`
# (see the ixaya-auth skill, Bootstrap section).

AGENT_BASE_URL=http://localhost:8080
AGENT_USERNAME=replace-with-a-valid-username
AGENT_PASSWORD=replace-with-a-valid-password
