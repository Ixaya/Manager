# sample.env — NON-SECRET runtime config (read by the PHP app and by
# scripts inside containers). Copy to <instance>.env. Credentials go in
# <instance>.priv.env.
#
# Duplicate keys are intentional: the "Docker" sections at the BOTTOM
# override the base sections above — the LAST occurrence of a key wins.
# Never "dedupe" this file.

# ═══════════════════════════════════════════════════════════════════════════
# Package (ixaya/manager) — framework variables (base: root .env.sample)
# ═══════════════════════════════════════════════════════════════════════════

APP_ENV=development
APP_TIMEZONE=

#cache.php
CACHE_ADAPTER=apc
CACHE_BACKUP=file
CACHE_KEY_PREFIX=
CACHE_SERIALIZATION=php
CACHE_DEFAULT_TTL=60
CACHE_ENABLE_LOGGING=false
# comma-separated IPs that bypass the cache entirely (pentest/dev)
CACHE_BYPASS_IPS=

#config.php
CF_HOST=
#CF_IMAGE_URL=
CF_LOG_THRESHOLD=4
# MGR_LOG_PATH: unified log root (trailing slash)
MGR_LOG_PATH=
CF_TIME_REFERENCE=
#config.php::session
CF_SESS_DRIVER=database
CF_SESS_COOKIE_NAME=ci_sessions
CF_SESS_EXPIRATION=0
CF_SESS_MATCH_IP=false
CF_SESS_TIME_TO_UPDATE=300
CF_SESS_REGENERATE_DESTROY=false
#config.php::cookie
CF_COOKIE_PREFIX=
CF_COOKIE_DOMAIN=
CF_COOKIE_PATH=/
CF_COOKIE_SECURE=false
CF_COOKIE_HTTPONLY=false

# DB_CHAR_SET/DB_COLLATION: utf8mb4/utf8mb4_0900_ai_ci (MySQL 8.x),
# utf8mb4/utf8mb4_uca1400_ai_ci (MariaDB), UTF8/empty (PostgreSQL).
#database.php
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_DRIVER=mysqli
DB_CHAR_SET=utf8mb4
DB_COLLATION=utf8mb4_0900_ai_ci

#ion_auth.php
AUTH_DB_CONNECTION=
AUTH_IDENTITY_EXTRA_COLUMNS=
AUTH_EMAIL_ACTIVATION=false
AUTH_MANUAL_ACTIVATION=
AUTH_TRACK_LOGIN_ATTEMPTS=true
AUTH_TRACK_LOGIN_IP=false
AUTH_MAX_LOGIN_ATTEMPTS=3
AUTH_LOCKOUT_TIME=600
AUTH_FORGOT_PASSWORD_EXPIRATION=1800
AUTH_RECHECK_TIMER=0
AUTH_HASH_METHOD=argon2id
AUTH_ARGON2_MEMORY_COST=65536
AUTH_ARGON2_TIME_COST=2
AUTH_ARGON2_THREADS=1
AUTH_BCRYPT_COST=10

#lib_amazon_aws.php
LIB_AWS_BUCKET=
LIB_AWS_BUCKET_URL=
LIB_AWS_REGION=us-east-1
LIB_AWS_CLOUD_FRONT_ID=
LIB_AWS_BEDROCK_MODEL_ID=

#lib_jwt.php
LIB_JWT_ACTIVE_CONFIG=default
LIB_JWT_DEFAULT_ALGORITHM=
LIB_JWT_DEFAULT_EXPIRY=900

#lib_mailing.php
LIB_MAIL_ACTIVE_CONFIG=default
LIB_MAIL_FROM_NAME=
LIB_MAIL_BBC_ENABLED=false
LIB_MAIL_USERAGENT=
#lib_mailing.php::$email_config['default']
LIB_MAIL_CF_DEFAULT_PROTOCOL=smtp
LIB_MAIL_CF_DEFAULT_SMTP_HOST=
LIB_MAIL_CF_DEFAULT_SMTP_PORT=
LIB_MAIL_CF_DEFAULT_SMTP_CRYPTO=none
LIB_MAIL_CF_DEFAULT_EMAIL_FROM=

#lib_websocket.php
WEBSOCKET_URL=ws://localhost:9000
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=9000
WEBSOCKET_MAX_CON=100
WEBSOCKET_MAX_CON_IP=10
WEBSOCKET_LOG_LEVEL=Debug
WEBSOCKET_JWT_AUDIENCE=websocket

#manager.php
MGR_EDITION=dev
MGR_LANGUAGES=
MGR_CACHE_ENABLE=true
MGR_CACHE_TIME=60
MGR_REST_TIME_ZONE=
MGR_MIGRATION_DB=default

#redis.php
LIB_REDIS_SOCKET=tcp
LIB_REDIS_HOST=127.0.0.1
LIB_REDIS_PORT=6379
LIB_REDIS_TIMEOUT=10
LIB_REDIS_DATABASE=
LIB_REDIS_CHANNEL_PREFIX=

#rest.php
REST_LANGUAGE=english
#rest.php::LOGS
REST_LOGS_PARAMS_MODE=get,post
REST_LOGS_PARAMS_PROTECTED=password
REST_LOGS_JSON_PARAMS=true
#rest.php::CORS
REST_CHECK_CORS=true
REST_ALLOW_ANY_CORS_DOMAIN=false
REST_ALLOWED_CORS=
REST_CORS_MAX_AGE=86400

# ═══════════════════════════════════════════════════════════════════════════
# Project — application variables (base: root .env.sample)
# ═══════════════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════════════════
# Docker specific — ALWAYS overrides the base values above
# (only keys whose docker value differs from the root sample appear here)
# ═══════════════════════════════════════════════════════════════════════════

#instance identity
APP_ENV=production
CI_ENV=production

#config.php — manager-logs volume
MGR_LOG_PATH=/var/log/manager/

#cache.php — must stay redis
CACHE_ADAPTER=redis
CACHE_DEFAULT_TTL=600

#redis.php → valkey-cache
LIB_REDIS_HOST=valkey-cache
LIB_REDIS_DATABASE=2

#config.php::session → valkey-state
CF_SESS_DRIVER=redis

#lib_websocket.php (profile ws; URL points at nginx's WS_PORT)
WEBSOCKET_PORT=9008
WEBSOCKET_URL=ws://localhost:8081

# ═══════════════════════════════════════════════════════════════════════════
# Docker deployment-dependent — bundled db profile ONLY. For RDS/external
# DB: delete this block and set the base DB_* values above instead.
# ═══════════════════════════════════════════════════════════════════════════

DB_HOST=mysql
DB_PORT=3306
DB_NAME=manager
DB_USER=manager
