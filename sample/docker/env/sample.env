# sample.env — docker OVERRIDES only (non-secret). Copy to <instance>.env.
# The base config comes from ../.env.<instance> (your copy of root .env.sample),
# layered FIRST by compose env_file; the keys here override it (last wins).
# Base keys are NOT restated here — root .env.sample is their single source,
# so the two files can never drift. Secrets go in <instance>.priv.env (mounted).

#instance identity
# CI_ENV must stay unset (secrets mount as the unqualified .env.priv — no
# tier selector .env.<CI_ENV>.priv must be chosen).
APP_ENV=production

#config.php — logging
# Docker logs under MGR_LOG_PATH. CF_LOG_PATH MUST be empty here: a project's
# base .env is not guaranteed to leave it empty, and a non-empty value would
# send the framework log elsewhere — so docker asserts empty rather than trust
# the base.
MGR_LOG_PATH=/var/log/manager/
CF_LOG_PATH=

#cache.php — must stay redis
CACHE_ADAPTER=redis
CACHE_DEFAULT_TTL=600

#redis.php → valkey-cache
LIB_REDIS_HOST=valkey-cache
LIB_REDIS_DATABASE=2

#config.php::session → valkey-state
CF_SESS_DRIVER=redis

#lib_websocket.php (profile ws; URL points at nginx's WS_PORT)
WEBSOCKET_PORT=9008
WEBSOCKET_URL=ws://localhost:8081

# ═══════════════════════════════════════════════════════════════════════════
# Docker deployment-dependent — bundled db profile ONLY. For RDS/external DB:
# delete this block and set DB_* in the base ../.env.<instance> instead.
# ═══════════════════════════════════════════════════════════════════════════

DB_HOST=mysql
DB_PORT=3306
DB_NAME=manager
DB_USER=manager
