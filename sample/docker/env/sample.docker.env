# sample.docker.env — DOCKER-INFRASTRUCTURE config (compose interpolation,
# build args, resource limits). Never loaded into any container environment.
# Copy to <instance>.docker.env.

#images
IMAGE_TAG=latest
IMAGE_REPO=manager/app
IMAGE_REPO_NGINX=manager/app-nginx

#ports (host → nginx; unique per instance)
HTTP_PORT=8080
WS_PORT=8081

#resources
PHP_PM_MAX_CHILDREN=20
PHP_MEM_LIMIT=1024m
PHP_CPUS=2.0
PHP_HEALTHCHECK_INTERVAL=30s
NGINX_MEM_LIMIT=128m
NGINX_CPUS=1.0
WS_MEM_LIMIT=256m
CRON_MEM_LIMIT=256m
VALKEY_STATE_MEM_LIMIT=384m
VALKEY_CACHE_MEM_LIMIT=256m
VALKEY_STATE_MAXMEMORY=256mb
VALKEY_CACHE_MAXMEMORY=128mb
MYSQL_MEM_LIMIT=1024m
MYSQL_CPUS=1.0
MARIADB_MEM_LIMIT=512m
MARIADB_CPUS=1.0
POSTGRES_MEM_LIMIT=512m
POSTGRES_CPUS=1.0

#host bind-mount sources (relative to docker/, or absolute)
MEDIA_PATH=../public/media
PRIVATE_PATH=../private

#entrypoint toggles
WAIT_FOR_DB=true
RUN_MIGRATIONS=false

#build
INCLUDE_TEST_MODULE=false

#dev live-code bind mode (-b) — path containing application/ and public/
#CODE_BIND_PATH=
#manager live-code bind mode (-m) — path containing ixaya/manager
#MANAGER_BIND_PATH=