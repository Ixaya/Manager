# PHPUnit environment. tests/Bootstrap.php sets CI_ENV=testing, so Env_lib
# loads this file INSTEAD of .env, plus .env.testing.priv as the priv layer.
# Committed, SECRETS never live here — only DB_PASS (and any other secret a
# test needs) goes in .env.testing.priv (gitignored). Process env outranks
# both, e.g. for a host-side run: DB_HOST=127.0.0.1 vendor/bin/phpunit

# development (not testing) so PHP errors surface in the phpunit output; the
# env FILE is still chosen by CI_ENV=testing (tests/Bootstrap.php), so this
# only affects ENVIRONMENT/error display. Set to testing to silence errors.
APP_ENV=development
APP_TIMEZONE=utc

#config.php — errors only; test noise belongs to the phpunit report
CF_LOG_THRESHOLD=1

# ── Database — the instance's normal dev DB. The tools service joins the
# stack network, so db services resolve by service name (postgres profile
# active here; mysql equivalents commented below).
DB_HOST=postgres
DB_PORT=5432
DB_NAME=manager_local
DB_USER=manager
DB_DRIVER=postgre
DB_CHAR_SET=utf8
DB_COLLATION=

# mysql profile equivalents:
# DB_HOST=mysql
# DB_PORT=3306
# DB_NAME=manager
# DB_DRIVER=mysqli
# DB_CHAR_SET=utf8mb4
# DB_COLLATION=utf8mb4_0900_ai_ci

# ── Not using docker: uncomment to run the suite against a local SQLite file
# instead of the stack DB. The schema must be migrated there first, and
# DB_USER stays required-or-fail even though SQLite ignores it.
# DB_DRIVER=sqlite3
# DB_NAME=/absolute/path/to/testing.sqlite
# DB_USER=phpunit
