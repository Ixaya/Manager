# ═══════════════════════════════════════════════════════════════════════════
# .env.sample.prod — PRODUCTION security checklist (non-secret, NOT a runtime
# file). Review EVERY key here before going live; values shown are the
# recommended prod baseline. Apply on top of your copied .env — Env_lib loads
# one base file, so loading this alone would drop everything it does not list.
# Credentials never live here — change those in .env.sample.priv.
# Lines marked "review" are judgment calls for your deployment, not fixed values.
# ═══════════════════════════════════════════════════════════════════════════

#instance mode — dev-only code paths and heavy debug logs gate on these
APP_ENV=production
MGR_EDITION=prod

#logging — dev uses 4 (full debug); prod keeps errors only
CF_LOG_THRESHOLD=1

#cookies — HTTPS-only, no JS access
CF_COOKIE_SECURE=true
CF_COOKIE_HTTPONLY=true

#session
CF_SESS_REGENERATE_DESTROY=true
# review: bind session to client IP (hardens, but breaks roaming/mobile)
CF_SESS_MATCH_IP=false
# review: session lifetime and id-rotation cadence for your app
CF_SESS_EXPIRATION=7200
CF_SESS_TIME_TO_UPDATE=300

#auth — brute-force + lockout: verify, do not loosen
AUTH_TRACK_LOGIN_ATTEMPTS=true
AUTH_TRACK_LOGIN_IP=true
AUTH_MAX_LOGIN_ATTEMPTS=3
AUTH_LOCKOUT_TIME=600
AUTH_FORGOT_PASSWORD_EXPIRATION=1800
# 0 disables the active-user DB recheck (deactivated users keep their session)
AUTH_RECHECK_TIMER=300
# review: account activation policy
AUTH_EMAIL_ACTIVATION=false
AUTH_MANUAL_ACTIVATION=true

#password hashing — tune costs to prod hardware (dev stays cheaper)
AUTH_HASH_METHOD=argon2id
AUTH_ARGON2_TIME_COST=3
AUTH_ARGON2_MEMORY_COST=65536
AUTH_ARGON2_THREADS=1
AUTH_BCRYPT_COST=12

#jwt
LIB_JWT_DEFAULT_ALGORITHM=HS256
LIB_JWT_DEFAULT_EXPIRY=300

#mail transport — never plaintext in prod
LIB_MAIL_CF_DEFAULT_SMTP_CRYPTO=tls

#cache — must stay empty in prod (any listed IP bypasses the cache entirely)
CACHE_BYPASS_IPS=

#rest api logging — strip secret-bearing params before they hit the api_log
REST_LOGS_PARAMS_PROTECTED=password,token,secret,authorization,api_key
# review: which params are logged at all
REST_LOGS_PARAMS_MODE=get,post

#rest cors — never allow any origin in prod
REST_CHECK_CORS=true
REST_ALLOW_ANY_CORS_DOMAIN=false

#websocket
WEBSOCKET_LOG_LEVEL=Warning
# review: connection ceilings (DoS) and bind scope for your topology
WEBSOCKET_MAX_CON=1000
WEBSOCKET_MAX_CON_IP=100
WEBSOCKET_HOST=0.0.0.0
