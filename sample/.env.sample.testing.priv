#database.php — the instance's normal dev DB credentials
DB_NAME=
DB_USER=
DB_PASS=

#tools joins the stack network, so db services resolve by name — uncomment one profile below

#postgres
# DB_HOST=postgres
# DB_PORT=
# DB_DRIVER=postgre
# DB_CHAR_SET=utf8
# DB_COLLATION=

#mysql
# DB_HOST=mysql
# DB_PORT=
# DB_DRIVER=mysqli
# DB_CHAR_SET=utf8mb4
# DB_COLLATION=utf8mb4_0900_ai_ci

#sqlite — no docker; schema must be migrated to this file first, DB_USER required-or-fail though sqlite ignores it
# DB_DRIVER=sqlite3
# DB_NAME=/absolute/path/to/testing.sqlite
# DB_USER=phpunit