# Ignore everything
*

# Then allow specific folders
!application/
!public/
!private/
!bin/
!patches/
!docker/

#  System files
**/.DS_Store
**/Thumbs.db

# Temp files
**/*.log
**/*.cache
**/*.tmp

# Extra files
!composer.json
# composer.lock IS needed in the build context for a reproducible,
# --classmap-authoritative install. Keep it un-ignored.
!composer.lock

# Local-only probes module (gitignored) — must never enter a build context
application/modules/probes/
# Hand-copied smoke module (for -b instances) — images bake it from
# docker/php/smoke/ via INCLUDE_SMOKE_MODULE, never from a leftover copy
application/modules/smoke/
