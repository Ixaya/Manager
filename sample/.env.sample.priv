# ═══════════════════════════════════════════════════════════════════════════
# Package (ixaya/manager) — framework secrets
# Every value in this file is a credential. Never commit the real .env.priv.
# ═══════════════════════════════════════════════════════════════════════════

#config.php
# generate: php public/index.php manager/tools/generate_enc_key
CF_ENCRYPTION_KEY=
#config.php::session
# redis: tcp://127.0.0.1:6379?timeout=10.0&prefix=mgr_session&database=1&auth=password
#   (the CI3 redis session driver parses `auth=`, NOT `password=`; timeout must be <int>.<int>)
# database driver: leave empty
CF_SESS_SAVE_PATH=

#database.php
# DB_USER is an identifier, not a secret — it lives in the non-priv env file
DB_PASS=
#database.php::secondary connection example
#DB_SEC_PASS=

#lib_amazon_aws.php
LIB_AWS_ACCESSKEY=
LIB_AWS_SECRETKEY=

#lib_jwt.php
LIB_JWT_DEFAULT_SECRET=

#lib_mailing.php::$email_config['default']
LIB_MAIL_CF_DEFAULT_SMTP_USER=
LIB_MAIL_CF_DEFAULT_SMTP_PASS=

#redis.php
LIB_REDIS_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════
# Project — application secrets
# Add your project's secrets below (module API keys, extra DB passwords).
# Keep the package section above untouched so framework upgrades diff cleanly.
# ═══════════════════════════════════════════════════════════════════════════
